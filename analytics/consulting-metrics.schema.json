{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Consulting Metrics Export",
  "description": "Schema for consulting business unit metrics exported to PantheonOS dashboard",
  "type": "object",
  "required": ["summary", "metrics", "meta"],
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "revenue_this_month": { "type": "number", "minimum": 0 },
        "revenue_last_month": { "type": "number", "minimum": 0 },
        "revenue_growth": { "type": "string" },
        "revenue_total": { "type": "number", "minimum": 0 },
        "active_clients": { "type": "integer", "minimum": 0 },
        "total_clients": { "type": "integer", "minimum": 0 },
        "pipeline_value": { "type": "number", "minimum": 0 },
        "proposals_outstanding": { "type": "integer", "minimum": 0 },
        "win_rate": { "type": "string" },
        "effective_rate": { "type": "string" },
        "hours_this_month": { "type": "number", "minimum": 0 },
        "hours_total": { "type": "number", "minimum": 0 },
        "last_updated": { "type": "string", "format": "date-time" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "finance": {
          "type": "object",
          "properties": {
            "revenue": {
              "type": "object",
              "properties": {
                "total": { "type": "number" },
                "this_month": { "type": "number" },
                "last_month": { "type": "number" },
                "growth_percent": { "type": "string" }
              }
            },
            "pipeline": {
              "type": "object",
              "properties": {
                "value": { "type": "number" },
                "proposals": { "type": "integer" }
              }
            },
            "expenses": {
              "type": "object",
              "properties": {
                "total": { "type": "number" },
                "this_month": { "type": "number" }
              }
            },
            "profitability": {
              "type": "object",
              "properties": {
                "gross": { "type": "number" },
                "effective_hourly_rate": { "type": "string" }
              }
            }
          }
        },
        "growth": {
          "type": "object",
          "properties": {
            "clients": {
              "type": "object",
              "properties": {
                "active": { "type": "integer" },
                "total": { "type": "integer" },
                "new_this_month": { "type": "integer" }
              }
            },
            "deals": {
              "type": "object",
              "properties": {
                "won": { "type": "integer" },
                "lost": { "type": "integer" },
                "win_rate": { "type": "string" },
                "proposals_sent": { "type": "integer" }
              }
            },
            "activity": {
              "type": "object",
              "properties": {
                "calls_this_month": { "type": "integer" },
                "hours_this_month": { "type": "number" },
                "calls_total": { "type": "integer" }
              }
            }
          }
        },
        "engagement": {
          "type": "object",
          "properties": {
            "client_health": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "revenue": { "type": "number" },
                  "hours": { "type": "number" },
                  "proposals": { "type": "integer" },
                  "calls": { "type": "integer" },
                  "last_contact": { "type": "string" },
                  "status": { "enum": ["lead", "prospect", "active"] }
                }
              }
            }
          }
        }
      }
    },
    "recent_activity": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "type": { "enum": ["call", "proposal", "win", "loss", "hours", "expense", "custom", "note"] },
          "client": { "type": "string" },
          "value": { "type": "number" },
          "note": { "type": "string" }
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "business_unit": { "const": "consulting" },
        "source": { "type": "string" },
        "exported_at": { "type": "string", "format": "date-time" },
        "version": { "const": "1.0" }
      }
    }
  }
}
