          "Identify D-words: dog, duck, dinosaur, donut, door"
        ],
        "skillsTargeted": ["letter-recognition", "phonemic-awareness", "vocabulary"],
        "prerequisites": ["quest-001-letter-a", "quest-002-letter-b", "quest-003-letter-c"],
