    "lessonCount": 6,
    "lessons": [
      {
        "lessonId": "quest-001-letter-a",
        "sequence": 1,
        "title": "Letter A Adventure",
        "duration": "6 minutes",
        "learningObjectives": [
          "Recognize uppercase and lowercase letter A",
          "Associate A with /æ/ sound",
          "Identify A-words: apple, ant, astronaut, anchor, acorn"
        ],
        "skillsTargeted": ["letter-recognition", "phonemic-awareness", "vocabulary"],
        "prerequisites": [],
        "assetsRequired": {
          "images": 24,
          "audio": 38
        }
      },
      {
        "lessonId": "quest-002-letter-b",
        "sequence": 2,
        "title": "Letter B Adventure",
        "duration": "6 minutes",
        "learningObjectives": [
          "Recognize uppercase and lowercase letter B",
          "Associate B with /b/ sound",
          "Identify B-words: butterfly, bear, ball, boat, banana"
        ],
        "skillsTargeted": ["letter-recognition", "phonemic-awareness", "vocabulary"],
        "prerequisites": ["quest-001-letter-a"],
        "assetsRequired": {
          "images": 24,
          "audio": 38
        }
      },
      {
        "lessonId": "quest-003-letter-c",
        "sequence": 3,
        "title": "Letter C Adventure",
        "duration": "6 minutes",
        "learningObjectives": [
          "Recognize uppercase and lowercase letter C",
          "Associate C with /k/ and /s/ sounds",
          "Identify C-words: cat, car, cookie, cup, carrot"
