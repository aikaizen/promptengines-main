{
  "version": 2,
  "name": "promptengines",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/flow$",
      "dest": "/flow/index.html"
    },
    {
      "src": "/flow/(.*)",
      "dest": "/flow/$1"
    },
    {
      "src": "/prototypes/flow-education/app/dist/assets/(.*)",
      "dest": "/prototypes/flow-education/app/dist/assets/$1"
    },
    {
      "src": "/prototypes/flow-education/app/dist/(.*)",
      "dest": "/prototypes/flow-education/app/dist/$1"
    },
    {
      "src": "/prototypes/(.*)",
      "dest": "/prototypes/$1"
    },
    {
      "src": "/floweducation",
      "dest": "/prototypes/flow-education/index.html"
    },
    {
      "src": "/floweducation/(.*)",
      "dest": "/prototypes/flow-education/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "github": {
    "enabled": true,
    "silent": false
  }
}

