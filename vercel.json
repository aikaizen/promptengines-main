{
  "version": 2,
  "name": "promptengines",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "lab.promptengines.com" }],
      "destination": "https://promptengines.com/labnotes/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/flow", "destination": "/flow/index.html" },
    { "source": "/flow/:path(.*)", "destination": "/flow/:path" },
    { "source": "/floweducation", "destination": "/prototypes/flow-education/index.html" },
    { "source": "/floweducation/:path(.*)", "destination": "/prototypes/flow-education/:path" }
  ],
  "github": {
    "enabled": true,
    "silent": false
  }
}
