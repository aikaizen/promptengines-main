{
  "version": 2,
  "name": "promptengines",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/flow$",
      "dest": "/flow/index.html"
    },
    {
      "src": "/flow/(.*)",
      "dest": "/flow/$1"
    },
    {
      "src": "/prototypes",
      "dest": "/prototypes/index.html"
    },
    {
      "src": "/prototypes/(.*)",
      "dest": "/prototypes/$1"
    },
    {
      "src": "/floweducation",
      "dest": "/prototypes/flow-education/index.html"
    },
    {
      "src": "/floweducation/(.*)",
      "dest": "/prototypes/flow-education/$1"
    }
  ],
  "github": {
    "enabled": false
  }
}

